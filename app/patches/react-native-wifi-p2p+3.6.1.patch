+  /**
+   * Retourne la VRAIE IP locale de cet appareil sur l'interface Wi-Fi Direct.
+   * La lib ne l'expose pas (getConnectionInfo ne renvoie que groupOwnerAddress).
+   * On parcourt TOUTES les interfaces et on prend celle dont l'IP est dans le
+   * subnet Wi-Fi Direct Android (192.168.49.x). Marche quel que soit le nom
+   * d'interface (p2p-wlan0-0, p2p0, etc. — variable selon le constructeur).
+   * Résout null si aucune IP p2p trouvée → le JS décide quoi faire (PAS de fallback hardcodé).
+   */
+  @ReactMethod
+  public void getP2pIpAddress(final Promise promise) {
+    try {
+      String found = null;
+      java.util.Enumeration<java.net.NetworkInterface> ifaces =
+          java.net.NetworkInterface.getNetworkInterfaces();
+      while (ifaces != null && ifaces.hasMoreElements()) {
+        java.net.NetworkInterface iface = ifaces.nextElement();
+        java.util.Enumeration<java.net.InetAddress> addrs = iface.getInetAddresses();
+        while (addrs.hasMoreElements()) {
+          java.net.InetAddress addr = addrs.nextElement();
+          if (addr.isLoopbackAddress()) continue;
+          String ip = addr.getHostAddress();
+          if (ip == null) continue;
+          // Le subnet Wi-Fi Direct d'Android est toujours 192.168.49.0/24
+          if (ip.startsWith("192.168.49.")) {
+            found = ip;
+            Log.i(TAG, "getP2pIpAddress: " + ip + " sur " + iface.getName());
+            break;
+          }
+        }
+        if (found != null) break;
+      }
+      promise.resolve(found);
+    } catch (Exception e) {
+      Log.e(TAG, "getP2pIpAddress error: " + e.getMessage());
+      promise.resolve(null);
+    }
+  }
+
+  /**
+   * V4.0 (BUG-047 fix) : Version améliorée de getP2pIpAddress.
+   * L'itel A50 (Mediatek) ne retourne pas toujours l'IP via l'itération générique.
+   * On essaie d'abord les noms d'interfaces connus, puis fallback sur l'itération générique.
+   * Retourne l'IP locale de l'appareil sur le subnet WiFi Direct (192.168.49.x).
+   */
+  @ReactMethod
+  public void getP2pLocalIp(final Promise promise) {
+    try {
+      String found = null;
+
+      // 1. Essayer les interfaces P2P connues ( Mediatek, Qualcomm, etc.)
+      String[] knownInterfaces = {"p2p-wlan0-0", "p2p0", "wlan0", "swlan0", "p2p-p2p0-0"};
+      for (String ifName : knownInterfaces) {
+        try {
+          java.net.NetworkInterface nif = java.net.NetworkInterface.getByName(ifName);
+          if (nif == null) continue;
+          java.util.Enumeration<java.net.InetAddress> addrs = nif.getInetAddresses();
+          while (addrs.hasMoreElements()) {
+            java.net.InetAddress addr = addrs.nextElement();
+            if (addr.isLoopbackAddress()) continue;
+            String ip = addr.getHostAddress();
+            if (ip == null) continue;
+            if (ip.startsWith("192.168.49.")) {
+              found = ip;
+              Log.i(TAG, "getP2pLocalIp (known iface " + ifName + "): " + ip);
+              break;
+            }
+          }
+          if (found != null) break;
+        } catch (Exception ignored) {}
+      }
+
+      // 2. Fallback : itérer toutes les interfaces (comme getP2pIpAddress)
+      if (found == null) {
+        java.util.Enumeration<java.net.NetworkInterface> ifaces =
+            java.net.NetworkInterface.getNetworkInterfaces();
+        while (ifaces != null && ifaces.hasMoreElements()) {
+          java.net.NetworkInterface iface = ifaces.nextElement();
+          java.util.Enumeration<java.net.InetAddress> addrs = iface.getInetAddresses();
+          while (addrs.hasMoreElements()) {
+            java.net.InetAddress addr = addrs.nextElement();
+            if (addr.isLoopbackAddress()) continue;
+            String ip = addr.getHostAddress();
+            if (ip == null) continue;
+            if (ip.startsWith("192.168.49.")) {
+              found = ip;
+              Log.i(TAG, "getP2pLocalIp (fallback iface " + iface.getName() + "): " + ip);
+              break;
+            }
+          }
+          if (found != null) break;
+        }
+      }
+
+      // 3. Dernier recours : lire depuis WifiP2pInfo si disponible
+      if (found == null && wifiP2pInfo != null && wifiP2pInfo.groupOwnerAddress != null) {
+        String goIp = wifiP2pInfo.groupOwnerAddress.getHostAddress();
+        if (goIp != null && goIp.startsWith("192.168.49.")) {
+          // On est peut-être le GO nous-même — dans ce cas l'IP GO est la nôtre
+          if (wifiP2pInfo.isGroupOwner) {
+            found = goIp;
+            Log.i(TAG, "getP2pLocalIp (isGroupOwner, GO addr): " + goIp);
+          } else {
+            // On est le client — l'IP du GO n'est pas la nôtre, mais on peut essayer
+            // de deviner notre IP en soustrayant la différence connue
+            Log.i(TAG, "getP2pLocalIp: GO=" + goIp + " mais on est client, IP locale inconnue");
+          }
+        }
+      }
+
+      Log.i(TAG, "getP2pLocalIp result: " + (found != null ? found : "NULL"));
+      promise.resolve(found);
+    } catch (Exception e) {
+      Log.e(TAG, "getP2pLocalIp error: " + e.getMessage());
+      promise.resolve(null);
+    }
+  }
