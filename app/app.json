{
  "expo": {
    "name": "Yabisso",
    "slug": "yabisso",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "devClient": true,
    "packagerOpts": {
      "hostType": "lan",
      "port": 8081
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.benksidney.yabisso",
      "permissions": [
        "SEND_SMS",
        "READ_SMS",
        "RECEIVE_SMS",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_STATE",
        "NEARBY_WIFI_DEVICES",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE",
        "READ_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "benksidney",
    "extra": {
      "eas": {
        "projectId": "067ab267-1b14-46ae-bc99-6e9649dc6640"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 35,
            "compileSdkVersion": 35
          }
        }
      ],
      "./plugins/withRemoveBundleCompression",
      "expo-camera",
      "expo-image-picker",
      "expo-document-picker",
      "expo-location",
      "expo-contacts",
      "expo-av",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Autoriser l'accès au microphone pour la recherche vocale",
          "speechRecognitionPermission": "Autoriser la reconnaissance vocale",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Autoriser Yabisso à utiliser le Bluetooth P2P pour l'inscription offline."
        }
      ],
      [
        "expo-nearby-connections",
        {
          "bonjourServicesName": "yabisso-mesh",
          "localNetworkUsagePermissionText": "Yabisso utilise le réseau local pour synchroniser les contenus Loba à proximité."
        }
      ],
      "react-native-compressor",
      "expo-video"
    ]
  }
}
